{
  "name": "sop-viewer",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start:api": "node scripts/local-cms.mjs",
    "start": "concurrently \"npm run start:api\" \"ng serve\"",
    "build": "npm run bundle-data:external && ng build && node scripts/build-file-static.mjs",
    "build:external": "npm run bundle-data:external && ng build && node scripts/build-file-static.mjs",
    "build:local": "ng build --base-href ./",
    "build:portable": "npm run bundle-data:inline && npm run build:local",
    "build:portable:external": "npm run bundle-data:external && npm run build:local",
    "build:file-static": "node scripts/build-file-static.mjs",
    "check:external-bundle": "node scripts/check-external-bundle.mjs",
    "preview:dist": "serve dist/sop-viewer/browser -l 8080",
    "bundle-data": "npm run bundle-data:external",
    "bundle-data:inline": "node scripts/bundle-data.mjs --inline",
    "bundle-data:external": "node scripts/bundle-data.mjs --external",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/animations": "^21.2.6",
    "@angular/cdk": "^21.2.4",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.4",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "docx": "^9.6.1",
    "file-saver": "^2.0.5",
    "fuse.js": "^7.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/file-saver": "^2.0.7",
    "angular-eslint": "21.3.1",
    "body-parser": "^2.2.2",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "eslint": "^10.0.3",
    "express": "^5.2.1",
    "jsdom": "^28.0.0",
    "multer": "^2.1.1",
    "prettier": "^3.8.1",
    "serve": "^14.2.5",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  }
}
